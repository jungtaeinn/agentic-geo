{
  "name": "agentic-geo",
  "author": "jungtaeinn",
  "license": "MIT",
  "private": true,
  "version": "0.1.0",
  "description": "Agentic GEO workspace that orchestrates PDP extraction, GEO schema/content generation, and validation sub agents for service-specific product optimization.",
  "keywords": [
    "agentic-geo",
    "generative-engine-optimization",
    "geo-orchestration",
    "sub-agent",
    "pdp-extraction",
    "schema-org",
    "json-ld",
    "rag",
    "product-content",
    "validation"
  ],
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "turbo run build",
    "build:pages": "NEXT_PUBLIC_DEPLOY_TARGET=github-pages turbo run build --filter=@agentic-geo/geo-generator",
    "build:pages:pdp": "NEXT_PUBLIC_DEPLOY_TARGET=github-pages turbo run build --filter=@agentic-geo/pdp-extractor",
    "changeset": "changeset",
    "dev": "turbo run dev --filter=@agentic-geo/geo-generator",
    "dev:geo-generator": "turbo run dev --filter=@agentic-geo/geo-generator",
    "dev:pdp-extractor": "turbo run dev --filter=@agentic-geo/pdp-extractor",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "turbo": "2.9.18",
    "typescript": "6.0.3"
  }
}
