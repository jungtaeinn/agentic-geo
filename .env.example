AGENTIC_GEO_PROVIDER=mock

# Optional when apps call a hosted API instead of mock mode.
NEXT_PUBLIC_AGENTIC_GEO_API_URL=

# Optional for packages/pdp-geo-generator-agent managed-vector-store-rag.
OPENAI_VECTOR_STORE_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# Azure API model deployments. Env names keep AZURE_OPENAI_* for compatibility.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_OCR_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_REASONING_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2025-04-01-preview
# Optional sampling temperature for chat/OCR model calls. Leave blank to omit it from requests
# so models that only accept their default value (e.g. gpt-5.5) are not rejected with HTTP 400.
AZURE_OPENAI_TEMPERATURE=

# AI Studio external-agent gateway (provider id: aistudio).
# Configured per-session from the app AI settings (Endpoint URL + API Key); no env vars are read for it.
# The single endpoint + Bearer key fronts Azure OpenAI (chat/embedding) and Bedrock (cohere rerank).
# Default model ids: reasoning/OCR=gpt-5.5, embedding=text-embedding-3-large, rerank=cohere.rerank-v3-5:0.

# Reranking. Default provider is Cohere Rerank; Azure AI Search semantic ranker can be selected in the UI.
AGENTIC_GEO_RERANKER_PROVIDER=cohere
AZURE_COHERE_RERANK_API_KEY=
AZURE_COHERE_RERANK_ENDPOINT=
AZURE_COHERE_RERANK_MODEL=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_INDEX_NAME=
AZURE_AI_SEARCH_SEMANTIC_CONFIGURATION=default
AZURE_AI_SEARCH_QUERY_LANGUAGE=ko-kr
